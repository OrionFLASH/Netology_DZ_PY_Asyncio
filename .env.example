# Путь к файлу SQLite (каталог data/ создаётся скриптами при необходимости)
DATABASE_PATH=./data/characters.db

# Базовый URL SWAPI (swapi.tech)
SWAPI_BASE_URL=https://www.swapi.tech/api

# Одновременных HTTP-запросов к API при загрузке деталей персонажей
HTTP_CONCURRENCY=6

# Таймаут одного HTTP-запроса, секунды (total и sock_read в aiohttp)
HTTP_TIMEOUT_TOTAL=600
